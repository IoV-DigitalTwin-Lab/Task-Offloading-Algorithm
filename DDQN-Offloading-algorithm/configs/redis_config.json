                "queue_length": 50.0,
                "cpu_utilization": 1.0
            },
            "vehicle": {
                "cpu_available": 5000.0,
                "mem_available": 4096.0,
                "cpu_utilization": 1.0,
                "mem_utilization": 1.0,
                "queue_length": 10.0,
                "speed": 25.0,
                "heading": 360.0,
                "distance_to_origin": 1000.0
            }
        }
    }
}
